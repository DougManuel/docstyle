{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dougmanuel.github.io/docstyle/schemas/report-envelope.v1.json",
  "title": "Docstyle vNext report envelope, version 1",
  "type": "object",
  "required": ["schemaVersion", "operation", "toolVersion", "result", "inputs", "findings"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "operation": { "type": "string", "minLength": 1 },
    "toolVersion": { "type": "string", "minLength": 1 },
    "generation": { "type": "integer", "minimum": 1 },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "hash"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
        }
      }
    },
    "result": { "enum": ["PASS", "PASS_WITH_WARNINGS", "FAIL"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "code", "message"],
        "properties": {
          "level": { "enum": ["info", "warning", "error"] },
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
