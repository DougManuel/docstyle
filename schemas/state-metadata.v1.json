{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dougmanuel.github.io/docstyle/schemas/state-metadata.v1.json",
  "title": "Docstyle vNext state metadata, version 1",
  "type": "object",
  "required": ["schemaVersion", "records", "profiles", "relationships"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "profiles": { "type": "object" },
    "records": {
      "type": "array",
      "items": {
        "anyOf": [
          { "$ref": "https://dougmanuel.github.io/docstyle/schemas/metadata-core.v1.json" },
          {
            "type": "object",
            "required": ["id", "recordType", "schemaVersion", "profile"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "recordType": { "type": "string" },
              "schemaVersion": { "type": "integer", "minimum": 1 },
              "profile": { "type": "string", "pattern": "^[a-z][a-z0-9-]*:[a-z][a-z0-9-]*$" },
              "privacy": { "enum": ["public", "restricted"] }
            }
          }
        ]
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "subject", "predicate", "object"],
        "properties": {
          "id": { "type": "string" },
          "subject": { "type": "string" },
          "predicate": { "type": "string" },
          "object": { "type": "string" }
        }
      }
    }
  }
}
