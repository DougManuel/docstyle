{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dougmanuel.github.io/docstyle/schemas/profiles/fixture.v1.json",
  "title": "Docstyle fixture record profile, version 1",
  "type": "object",
  "required": ["id", "recordType", "schemaVersion", "label"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "recordType": { "const": "fixture-record" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "privacy": { "enum": ["public", "restricted"] },
    "profile": { "type": "string" },
    "label": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } },
    "category": { "enum": ["alpha", "beta"] },
    "region": { "type": "string" }
  }
}
