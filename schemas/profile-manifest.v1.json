{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dougmanuel.github.io/docstyle/schemas/profile-manifest.v1.json",
  "title": "Docstyle profile manifest, version 1",
  "type": "object",
  "required": ["id", "version", "schema", "recordTypes"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*:[a-z][a-z0-9-]*$" },
    "version": { "type": "string", "pattern": "^[0-9]+[.][0-9]+[.][0-9]+$" },
    "schema": { "type": "string" },
    "recordTypes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "classes": { "type": "array", "items": { "type": "string" } },
    "regionRoles": { "type": "array", "items": { "type": "string" } },
    "predicates": { "type": "array", "items": { "type": "string" } },
    "mappings": { "type": "object" },
    "migratesFrom": { "type": "array", "items": { "type": "string" } }
  }
}
