{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dougmanuel.github.io/docstyle/schemas/state-citations.v1.json",
  "title": "Docstyle vNext state citations, version 1",
  "type": "object",
  "required": ["schemaVersion", "citations"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "zoteroPref": { "type": "string" },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "keys", "instruction"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "keys": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
          "instruction": { "type": "string", "minLength": 1 },
          "privacy": { "enum": ["public", "restricted"] }
        }
      }
    }
  }
}
